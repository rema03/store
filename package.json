{
  "name": "fashion-mall",
  "version": "1.0.0",
  "description": "Full-featured fashion shopping mall built with Next.js, TypeScript, DevUp UI, Prisma, and Toss Payments",
  "scripts": {
    "postinstall": "node scripts/patch-devup-ui-next-plugin.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-standalone.mjs",
    "start:next": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@devup-ui/next-plugin": "^1.0.78",
    "@devup-ui/react": "^1.0.37",
    "@devup-ui/reset-css": "^1.0.24",
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.7.1",
    "@tosspayments/payment-sdk": "^1.9.3",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "lucide-react": "^0.263.1",
    "next": "^14.1.0",
    "next-auth": "^4.24.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "uuid": "^14.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.1.0",
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}

