# Database
DATABASE_URL="postgresql://store:replace-this-store-db-password@store-db:5432/store"

# NextAuth
NEXTAUTH_SECRET="replace-this-with-a-long-random-secret"
NEXTAUTH_URL="https://shop.jimindev.com"

# Toss Payments (Test Keys)
NEXT_PUBLIC_TOSS_CLIENT_KEY="test_ck_your_test_key_here"
TOSS_SECRET_KEY="test_sk_your_test_key_here"
TOSS_SUCCESS_URL="https://shop.jimindev.com/checkout/success"
TOSS_FAIL_URL="https://shop.jimindev.com/checkout/fail"
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD="50000"
NEXT_PUBLIC_SHIPPING_FEE="3000"
MAX_UPLOAD_BYTES="5242880"

# Image Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Or use Supabase Storage
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
